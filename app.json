      "bundleIdentifier": "com.msin.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#FAF7F2"
      },
      "package": "com.msin.app"
    },
    "scheme": "msin",
    "plugins": [
      "expo-router",
      "expo-asset"
    ]
  }
}
